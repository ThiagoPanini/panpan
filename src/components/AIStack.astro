    return '<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-label="Cognition"><path d="M5 3h7c5.5 0 8 3.1 8 9s-2.5 9-8 9H5V3zm3 3v12h4c3.3 0 5-2.2 5-6s-1.7-6-5-6H8z"/></svg>';
