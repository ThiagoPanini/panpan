    return '<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-label="OpenAI"><path d="M22.282 9.821a6 6 0 0 0-.516-4.91 6.05 6.05 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a6 6 0 0 0-3.998 2.9 6.05 6.05 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.05 6.05 0 0 0 6.515 2.9A6 6 0 0 0 13.26 24a6.06 6.06 0 0 0 5.772-4.206 6 6 0 0 0 3.997-2.9 6.06 6.06 0 0 0-.747-7.073M13.26 22.43a4.48 4.48 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.8.8 0 0 0 .392-.681v-6.737l2.02 1.168a.07.07 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494M3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.77.77 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646M2.34 7.896a4.5 4.5 0 0 1 2.366-1.973V11.6a.77.77 0 0 0 .388.677l5.815 3.354-2.02 1.168a.08.08 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855-5.833-3.387L15.119 7.2a.08.08 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667m2.01-3.023-.141-.085-4.774-2.782a.78.78 0 0 0-.785 0L9.409 9.23V6.897a.07.07 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.8.8 0 0 0-.393.681zm1.097-2.365 2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5Z"/></svg>';
  }
  return '<svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-label="GitHub Copilot"><path d="M23.922 16.997C23.061 18.492 18.063 22.02 12 22.02S.939 18.492.078 16.997A.6.6 0 0 1 0 16.741v-2.869a1 1 0 0 1 .053-.22c.372-.935 1.347-2.292 2.605-2.656.167-.429.414-1.055.644-1.517a10 10 0 0 1-.052-1.086c0-1.331.282-2.499 1.132-3.368.397-.406.89-.717 1.474-.952C7.255 2.937 9.248 1.98 11.978 1.98s4.767.957 6.166 2.093c.584.235 1.077.546 1.474.952.85.869 1.132 2.037 1.132 3.368 0 .368-.014.733-.052 1.086.23.462.477 1.088.644 1.517 1.258.364 2.233 1.721 2.605 2.656a.8.8 0 0 1 .053.22v2.869a.6.6 0 0 1-.078.256m-11.75-5.992h-.344a4 4 0 0 1-.355.508c-.77.947-1.918 1.492-3.508 1.492-1.725 0-2.989-.359-3.782-1.259a2 2 0 0 1-.085-.104L4 11.746v6.585c1.435.779 4.514 2.179 8 2.179s6.565-1.4 8-2.179v-6.585l-.098-.104s-.033.045-.085.104c-.793.9-2.057 1.259-3.782 1.259-1.59 0-2.738-.545-3.508-1.492a4 4 0 0 1-.355-.508m2.328 3.25c.549 0 1 .451 1 1v2c0 .549-.451 1-1 1s-1-.451-1-1v-2c0-.549.451-1 1-1m-5 0c.549 0 1 .451 1 1v2c0 .549-.451 1-1 1s-1-.451-1-1v-2c0-.549.451-1 1-1m3.313-6.185c.136 1.057.403 1.913.878 2.497.442.544 1.134.938 2.344.938 1.573 0 2.292-.337 2.657-.751.384-.435.558-1.15.558-2.361 0-1.14-.243-1.847-.705-2.319-.477-.488-1.319-.862-2.824-1.025-1.487-.161-2.192.138-2.533.529-.269.307-.437.808-.438 1.578v.021q0 .397.063.893m-1.626 0q.063-.496.063-.894v-.02c-.001-.77-.169-1.271-.438-1.578-.341-.391-1.046-.69-2.533-.529-1.505.163-2.347.537-2.824 1.025-.462.472-.705 1.179-.705 2.319 0 1.211.175 1.926.558 2.361.365.414 1.084.751 2.657.751 1.21 0 1.902-.394 2.344-.938.475-.584.742-1.44.878-2.497"/></svg>';
}

// ── AI Artifacts ─────────────────────────────────────────────────────────────

const artifacts = [
  {
    label: 'AGENTS.md',
    desc: 'Repository-level instructions that give AI agents full context about the codebase',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
  },
  {
    label: 'Custom Skills',
    desc: 'Reusable prompt-based capabilities that encode domain expertise into repeatable actions',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>',
  },
  {
    label: 'SDD Specs',
    desc: 'Specification-Driven Development documents — write the contract before a single line of code',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16,18 22,12 16,6"/><polyline points="8,6 2,12 8,18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>',
  },
  {
    label: 'Playbooks',
    desc: 'Step-by-step execution guides that encode team conventions into AI-actionable workflows',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="14" y2="11"/></svg>',
  },
];

// ── Language expansion data ───────────────────────────────────────────────────

const SIMPLE_ICONS_SLUG: Record<string, string> = {
  Python:     'python',
  Terraform:  'terraform',
  TypeScript: 'typescript',
  JavaScript: 'javascript',
  Astro:      'astro',
  HTML:       'html5',
  CSS:        'css3',
  Shell:      'gnubash',
  Go:         'go',
  Rust:       'rust',
  Docker:     'docker',
  Makefile:   'gnu',
};

const LANGUAGE_COLORS: Record<string, string> = {
  Python:     '#3572A5',
  Terraform:  '#7B42BC',
  TypeScript: '#3178C6',
  JavaScript: '#F1E05A',
  Astro:      '#FF5D01',
  HTML:       '#E34C26',
  CSS:        '#563D7C',
  Shell:      '#89E051',
  Go:         '#00ADD8',
  Rust:       '#DEA584',
  Docker:     '#2496ED',
  Makefile:   '#427819',
};

const topLanguages = languageData.topLanguages ?? [];
const primaryStack = languageData.primaryStack ?? ['Python', 'Terraform'];
const generatedAt = languageData.generatedAt ?? '';

function formatDate(iso: string): string {
  if (!iso) return '';
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// ── Coverage data ────────────────────────────────────────────────────────────

interface CoverageRepo {
  name: string;
  coverage: number;
  branch: string;
}

const averageCoverage = Number(coverageData.averageCoverage ?? 0);
const covRepoCount = Number(coverageData.repoCount ?? 0);
const coverageGeneratedAt = coverageData.generatedAt ?? '';
const includedRepos: CoverageRepo[] = Array.isArray(coverageData.includedRepos)
  ? [...coverageData.includedRepos as CoverageRepo[]].sort((a, b) => b.coverage - a.coverage)
  : [];

// Before/After AI splits
const beforeAIRepos = includedRepos.filter(r => ['pynvest', 'nbaflow'].includes(r.name));
const afterAIRepos = includedRepos.filter(r => ['aidriven'].includes(r.name));

function coverageTier(pct: number): 'low' | 'mid' | 'high' {
  if (pct >= 90) return 'high';
  if (pct >= 70) return 'mid';
  return 'low';
}

function tierLabel(tier: 'low' | 'mid' | 'high'): string {
  if (tier === 'high') return 'Strong';
  if (tier === 'mid') return 'Healthy';
  return 'Improving';
}

const hasCoverageData = covRepoCount > 0 && averageCoverage > 0;

// ── Icons — fetched at build time, inlined into HTML ──

async function fetchSimpleIcon(slug: string): Promise<string | null> {
  try {
    const res = await fetch(`https://cdn.simpleicons.org/${slug}`);
    if (!res.ok) return null;
    const svg = await res.text();
    return svg.replace(/fill="(?!none)[^"]+"/g, 'fill="currentColor"');
  } catch {
    return null;
  }
}

const [codecovIcon, githubIcon] = await Promise.all([
  fetchSimpleIcon('codecov'),
  fetchSimpleIcon('github'),
]);

// ── Shared "last updated" ──
const latestUpdate = (() => {
  const a = generatedAt ? new Date(generatedAt).getTime() : 0;
  const b = coverageGeneratedAt ? new Date(coverageGeneratedAt).getTime() : 0;
  if (a === 0 && b === 0) return '';
  return a >= b ? generatedAt : coverageGeneratedAt;
})();

---

<section id="ai-stack" class="ais">

  <canvas class="ais-canvas" aria-hidden="true"></canvas>

  <!-- ═══ Section Header ═══ -->
  <div class="ais-header">
    <span class="ais-overline">AI Driven Development</span>
    <h3 class="ais-title">My AI Stack</h3>
    <p class="ais-subtitle">
      Paid tools, structured artifacts, and measurable impact — this is how I turn AI into a force multiplier.
    </p>
  </div>

  <!-- ═══ 1. Tool Command Center — compact orchestration strip ═══ -->
  <div class="ais-command" aria-label="AI tools I use">


    <!-- License legend —- top left above tools -->
    <div class="ais-tools-legend" aria-label="License context legend">
      <span class="ais-legend-item">
        <svg class="ais-badge-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.5 14V8.5L8 3l5.5 5.5V14H10v-3.5H6V14z"/></svg>
        Personal license
      </span>
      <span class="ais-legend-item">
        <svg class="ais-badge-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1.5" y="5" width="13" height="9" rx="1.2"/><path d="M5 5V3.5a3 3 0 0 1 6 0V5"/></svg>
        Professional license
      </span>
    </div>

    <!-- Tool nodes — compact chips -->
    <div class="ais-tools-row">
      {tools.map((tool, i) => (
        <div
          class="ais-tool"
          style={`--tool-accent: ${tool.accentColor}; --tool-index: ${i}`}
          tabindex="0"
          role="article"
          aria-label={`${tool.name} by ${tool.provider}`}
        >
          <!-- Glow background -->
          <div class="ais-tool-glow" aria-hidden="true"></div>

          <!-- Icon -->
          <div class="ais-tool-icon" aria-hidden="true" set:html={getToolIcon(tool.provider)}></div>

          <!-- Info -->
          <div class="ais-tool-info">
            <span class="ais-tool-name">{tool.name}</span>
            <span class="ais-tool-role">{tool.role}</span>
          </div>

          <!-- License badges -->
          <div class="ais-tool-badges">
            {tool.licenses.map((lic) => (
              <span class={`ais-badge ais-badge--${lic.context.toLowerCase()}`}>
                {lic.context === 'Personal' ? (
                  <svg class="ais-badge-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.5 14V8.5L8 3l5.5 5.5V14H10v-3.5H6V14z"/></svg>
                ) : (
                  <svg class="ais-badge-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1.5" y="5" width="13" height="9" rx="1.2"/><path d="M5 5V3.5a3 3 0 0 1 6 0V5"/></svg>
                )}
                {lic.tier}
              </span>
            ))}
          </div>

          <!-- Signal line (animated connection) -->
          <div class="ais-tool-signal" aria-hidden="true"></div>
        </div>
      ))}
    </div>
  </div>

  {/* ═══ 2. AI Artifacts — cross-cutting shared layer ═══
  <div class="ais-artifacts" aria-label="AI development artifacts">
    <div class="ais-artifacts-header">
      <span class="ais-artifacts-overline">AI Artifacts</span>
      <p class="ais-artifacts-subtitle">Cross-cutting resources shared across every AI solution in the stack</p>
    </div>

    <!-- Visual bridge showing artifacts span all tools -->
    <div class="ais-artifacts-bridge" aria-hidden="true">
      <span class="ais-bridge-line"></span>
      <span class="ais-bridge-label">shared by all tools above</span>
      <span class="ais-bridge-line"></span>
    </div>

    <div class="ais-artifacts-grid">
      {artifacts.map((art, i) => (
        <div class="ais-artifact" style={`--art-index: ${i}`}>
          <div class="ais-artifact-icon" aria-hidden="true" set:html={art.icon}></div>
          <div class="ais-artifact-content">
            <span class="ais-artifact-label">{art.label}</span>
            <span class="ais-artifact-desc">{art.desc}</span>
          </div>
          <div class="ais-artifact-pulse" aria-hidden="true"></div>
        </div>
      ))}
    </div>
  </div>
  */}

  <!-- ═══ 3. AI Impact — preserved narrative with enhanced visuals ═══ -->
  <div class="ais-impact">

    <div class="ais-impact-header">
      <span class="ais-impact-overline">
        AI Impact
        <span class="ais-impact-signal" aria-hidden="true"></span>
      </span>
      <p class="ais-impact-subtitle">
        AI expanded what I'm able to learn and raised the bar on how I test it
      </p>
    </div>

    <div class="ais-impact-grid">

      <!-- ═══ Left: Language Expansion ═══ -->
      {topLanguages.length > 0 && (
        <div class="ais-impact-col ais-impact-col--lang">

          <div class="ais-expansion-header">
            <span class="ais-expansion-overline">
              Knowledge Expansion
              <span class="ais-live" aria-hidden="true">
                <span class="ais-live-dot"></span>
                live
              </span>
            </span>
            <h6 class="ais-expansion-title">How AI helped me learn new things</h6>
            <p class="ais-expansion-methodology">
              Language composition derived from the {languageData.repoCount} most recently active
              repositories via the GitHub API.
            </p>
          </div>

          <div class="ais-expansion-timeline">

            <!-- Before AI -->
            <div class="ais-expansion-before">
              <span class="ais-expansion-phase-label">Before AI</span>
              <span class="ais-expansion-phase-sub">Focused on well-mastered languages</span>
              <div class="ais-expansion-baseline">
                {primaryStack.map((lang) => (
                  <div class="ais-expansion-baseline-tech">
                    {SIMPLE_ICONS_SLUG[lang]
                      ? (
                        <span
                          class="ais-expansion-before-icon"
                          aria-hidden="true"
                          style={`--icon-url: url('https://cdn.simpleicons.org/${SIMPLE_ICONS_SLUG[lang]}'); --lang-color: ${LANGUAGE_COLORS[lang] ?? '#7A7A7A'}`}
                        />
                      )
                      : (
                        <span
                          class="ais-expansion-before-dot"
                          style={`background: ${LANGUAGE_COLORS[lang] ?? '#7A7A7A'}`}
                          aria-hidden="true"
                        />
                      )
                    }
                    <span class="ais-expansion-baseline-name">{lang}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- Connector -->
            <div class="ais-expansion-connector" aria-hidden="true">
              <span class="ais-expansion-connector-line"></span>
              <span class="ais-expansion-connector-node"></span>
              <span class="ais-expansion-connector-line"></span>
            </div>

            <!-- After AI -->
            <div class="ais-expansion-after">
              <span class="ais-expansion-phase-label">After AI</span>
              <span class="ais-expansion-phase-sub">Exploring new languages through AI-accelerated learning</span>
              <div class="ais-expansion-languages">
                {topLanguages.map((lang) => (
                  <div class="ais-expansion-lang">
                    <div class="ais-expansion-lang-info">
                      {SIMPLE_ICONS_SLUG[lang.name]
                        ? (
                          <span
                            class="ais-expansion-lang-icon"
                            aria-hidden="true"
                            style={`--icon-url: url('https://cdn.simpleicons.org/${SIMPLE_ICONS_SLUG[lang.name]}'); --lang-color: ${LANGUAGE_COLORS[lang.name] ?? '#7A7A7A'}`}
                          />
                        )
                        : (
                          <span
                            class="ais-expansion-lang-dot"
                            style={`background: ${LANGUAGE_COLORS[lang.name] ?? '#7A7A7A'}`}
                            aria-hidden="true"
                          />
                        )
                      }
                      <span class="ais-expansion-lang-name">{lang.name}</span>
                      <span class="ais-expansion-lang-pct">{lang.percentage}%</span>
                    </div>
                    <div class="ais-expansion-lang-bar" aria-hidden="true">
                      <div
                        class="ais-expansion-lang-fill"
                        style={`width: ${lang.percentage}%; --lang-color: ${LANGUAGE_COLORS[lang.name] ?? 'var(--color-accent)'}`}
                      />
                    </div>
                  </div>
                ))}
              </div>
            </div>

          </div>

        </div>
      )}

      <!-- Vertical separator -->
      <div class="ais-impact-sep" aria-hidden="true"></div>

      <!-- ═══ Right: Coverage — Before/After AI ═══ -->
      <div class="ais-impact-col ais-impact-col--cov">

        <div class="cov2-header">
          <span class="cov2-overline">
            Testing evolution
            <span class="ais-live" aria-hidden="true">
              <span class="ais-live-dot"></span>
              live
            </span>
          </span>
          <h6 class="cov2-title">How AI raised my quality bar</h6>
          <p class="cov2-methodology">
            Arithmetic mean of the latest line-coverage report from some of my GitHub repos tracked by Codecov
          </p>
        </div>

        {hasCoverageData ? (
          <>
            <div class="cov2-timeline">

              <!-- Before AI -->
              <div class="cov2-phase cov2-phase--before">
                <span class="cov2-phase-label">Before AI</span>
                <span class="cov2-phase-sub">Tests were an afterthought in earlier projects</span>
                <div class="cov2-bars" role="list" aria-label="Pre-AI coverage">
                  {beforeAIRepos.map((repo) => {
                    const tier = coverageTier(repo.coverage);
                    return (
                      <div class={`cov2-bar cov2-bar--${tier}`} role="listitem">
                        <div class="cov2-bar-row">
                          {githubIcon && (
                            <span class="cov2-bar-gh" aria-hidden="true" set:html={githubIcon} />
                          )}
                          <span class="cov2-bar-name">{repo.name}</span>
                          <span class="cov2-bar-tier" aria-hidden="true">{tierLabel(tier)}</span>
                          <span class="cov2-bar-pct">{repo.coverage.toFixed(1)}%</span>
                        </div>
                        <div class="cov2-bar-track" aria-hidden="true">
                          <div class="cov2-bar-fill" style={`width: ${repo.coverage}%`} />
                        </div>
                        <span class="cov2-bar-sr">
                          {repo.name}: {repo.coverage.toFixed(1)} percent coverage on {repo.branch}
                        </span>
                      </div>
                    );
                  })}
                </div>
              </div>

              <!-- Connector -->
              <div class="cov2-connector" aria-hidden="true">
                <span class="cov2-connector-line"></span>
                <span class="cov2-connector-node"></span>
                <span class="cov2-connector-line"></span>
              </div>

              <!-- After AI -->
              <div class="cov2-phase cov2-phase--after">
                <span class="cov2-phase-label">After AI</span>
                <span class="cov2-phase-sub">AI-assisted development raised the quality bar</span>
                <div class="cov2-bars" role="list" aria-label="Post-AI coverage">
                  {afterAIRepos.map((repo) => {
                    const tier = coverageTier(repo.coverage);
                    return (
                      <div class={`cov2-bar cov2-bar--${tier}`} role="listitem">
                        <div class="cov2-bar-row">
                          {githubIcon && (
                            <span class="cov2-bar-gh" aria-hidden="true" set:html={githubIcon} />
                          )}
                          <span class="cov2-bar-name">{repo.name}</span>
                          <span class="cov2-bar-tier" aria-hidden="true">{tierLabel(tier)}</span>
                          <span class="cov2-bar-pct">{repo.coverage.toFixed(1)}%</span>
                        </div>
                        <div class="cov2-bar-track" aria-hidden="true">
                          <div class="cov2-bar-fill" style={`width: ${repo.coverage}%`} />
                        </div>
                        <span class="cov2-bar-sr">
                          {repo.name}: {repo.coverage.toFixed(1)} percent coverage on {repo.branch}
                        </span>
                      </div>
                    );
                  })}
                </div>
              </div>

            </div>
          </>
        ) : (
          <p class="cov2-empty">
            Coverage data is being refreshed. Check back after the next CI sync.
          </p>
        )}

      </div>

    </div>

    <!-- Shared last-updated -->
    {latestUpdate && (
      <span class="ais-impact-updated">
        Last updated {formatDate(latestUpdate)}
      </span>
    )}

  </div>
</section>

<style>
  @import '../styles/ai-stack.css';
  @import '../styles/coverage-proof.css';
</style>

