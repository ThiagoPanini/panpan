  import { initAIStackCanvas } from '../scripts/aiStackCanvas';

  document.addEventListener('DOMContentLoaded', () => {
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      initAIStackCanvas();
    }
  });
</script>
