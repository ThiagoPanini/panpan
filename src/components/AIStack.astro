  context: 'Personal' | 'Professional';
}

interface Tool {
  name: string;
  provider: string;
  role: string;
  licenses: License[];
  accentColor: string;
}

const tools: Tool[] = [
  {
    name: 'Claude Code',
    provider: 'Anthropic',
    role: 'Agentic pair-programmer',
    licenses: [{ tier: 'Pro', context: 'Personal' }],
    accentColor: '#CC785C',
  },
  {
    name: 'GitHub Copilot',
    provider: 'Microsoft',
    role: 'IDE-native completions & chat',
    licenses: [
      { tier: 'Pro', context: 'Personal' },
      { tier: 'Enterprise', context: 'Professional' },
    ],
    accentColor: '#6E40C9',
  },
  {
    name: 'GPT / ChatGPT',
    provider: 'OpenAI',
    role: 'Prompt engineering specialist',
    licenses: [
      { tier: 'Plus', context: 'Personal' },
      { tier: 'Enterprise', context: 'Professional' },
    ],
    accentColor: '#10A37F',
  },
  {
    name: 'Devin',
    provider: 'Cognition',
    role: 'Autonomous engineer',
    licenses: [{ tier: 'Enterprise', context: 'Professional' }],
    accentColor: '#5B7CFA',
  },
];

