---
/**
 * Projects — top-3 most recently active GitHub repositories.
 *
 * Repo discovery  : /users/{user}/repos?sort=pushed — no token required.
 *                   Falls back to REPO_FALLBACK if the request fails.
 * Activity signal : pushed_at (most recent push date) — more precise than
 *                   updated_at, which also changes on metadata edits.
 * Commit chart    : seismograph-style vertical spikes from a baseline.
 *                   Replaces the old area sparkline for a cleaner, more
 *                   technical look consistent with the AI Usage waveforms.
 * Daily digest    : built by .github/workflows/daily-digest.yml and stored
 *                   at src/data/github-digest/latest.json. Consumed at
 *                   build time — zero runtime cost.
 */

import digestRaw from '../data/github-digest/latest.json';

// ── Config ───────────────────────────────────────────────────────────────────

const GITHUB_USERNAME = 'ThiagoPanini';
const GITHUB_TOKEN    = import.meta.env.GITHUB_ACCESS_TOKEN;
// Fallback repo names used when the dynamic discovery API call fails
const REPO_FALLBACK   = ['panpan', 'aidriven', 'aidriven-resources'];

const githubHeaders = {
  Accept: 'application/vnd.github+json',
  ...(GITHUB_TOKEN ? { Authorization: `Bearer ${GITHUB_TOKEN}` } : {}),
};

// ── Types ────────────────────────────────────────────────────────────────────

interface Project {
  rank: number;
  name: string;
  description: string;
  language: string;
  technologies: string[];
  stars: number;
  forks: number;
  url: string;
  topics: string[];
  /** Most recent push date — used as the primary recency signal. */
  pushedAt: string;
  updatedAt: string;
  commitActivity: number[];
}

interface Digest {
  date: string;
  generatedAt: string;
  summary: string;
  stats: {
    commits: number;
    reposTouched: string[];
    pullRequests: number;
  };
  source: string;
}

// ── Repo discovery ────────────────────────────────────────────────────────────

/**
 * Returns the names of the 3 most recently pushed-to non-fork repos.
 * Sorted by pushed_at — a stronger activity signal than updated_at.
 * Falls back to REPO_FALLBACK if the API call fails or returns < 3.
 */
async function fetchTopRepoNames(): Promise<string[]> {
  try {
    const res = await fetch(
      `https://api.github.com/users/${GITHUB_USERNAME}/repos?sort=pushed&per_page=20&type=owner`,
      { headers: githubHeaders },
    );
    if (!res.ok) return REPO_FALLBACK;
    const repos: any[] = await res.json();
    const names = repos
      .filter((r) => !r.fork)
      .slice(0, 3)
      .map((r) => r.name as string);
    return names.length >= 3 ? names : REPO_FALLBACK;
  } catch {
    return REPO_FALLBACK;
  }
}

// ── Commit activity ───────────────────────────────────────────────────────────

/**
 * Fetch 52-week commit activity. Tries the stats endpoint first
 * (cheap, single request) and falls back to the commits list API,
 * which is synchronous and always responds. Guarantees 52 buckets.
 */
async function fetchCommitActivity(name: string): Promise<number[]> {
  const fromStats = await fetchFromStatsEndpoint(name);
  if (fromStats && fromStats.length >= 2 && fromStats.some((v) => v > 0)) {
    return fromStats;
  }
  const fromCommits = await fetchFromCommitsEndpoint(name);
  if (fromCommits.some((v) => v > 0)) return fromCommits;
  // Last resort: prefer whichever non-empty array we got, else 52 zeros.
  if (fromStats && fromStats.length >= 2) return fromStats;
  return new Array(52).fill(0);
}

/**
 * /stats/commit_activity is async on GitHub's side: it may answer
 * 202 (computing), or worse, 200 with an empty body while still
 * computing. Retry both cases with exponential backoff.
 */
async function fetchFromStatsEndpoint(name: string): Promise<number[] | null> {
  const url = `https://api.github.com/repos/${GITHUB_USERNAME}/${name}/stats/commit_activity`;
  const delays = [800, 1500, 2500, 4000, 6000];
  for (const delay of delays) {
    try {
      const res = await fetch(url, { headers: githubHeaders });
      if (res.status === 202) {
        await new Promise((r) => setTimeout(r, delay));
        continue;
      }
      if (res.status === 403 || res.status === 429) return null; // rate-limited
      if (!res.ok) return null;
      const data: Array<{ total: number }> = await res.json();
      if (!Array.isArray(data) || data.length === 0) {
        // 200 + empty body: GitHub is still computing — wait & retry.
        await new Promise((r) => setTimeout(r, delay));
        continue;
      }
      return data.map((w) => w.total ?? 0);
    } catch {
      return null;
    }
  }
  return null;
}

/**
 * Fallback: list commits from the past 52 weeks (paginated) and
 * bucket them by week. Synchronous on GitHub's side, always works
 * for any repo the token can read.
 */
async function fetchFromCommitsEndpoint(name: string): Promise<number[]> {
  const WEEKS = 52;
  const buckets = new Array(WEEKS).fill(0);
  const weekMs = 7 * 86400000;
  const since = new Date(Date.now() - WEEKS * weekMs);
  const startMs = since.getTime();

  for (let page = 1; page <= 10; page++) {
    try {
      const url =
        `https://api.github.com/repos/${GITHUB_USERNAME}/${name}/commits` +
        `?since=${since.toISOString()}&per_page=100&page=${page}`;
      const res = await fetch(url, { headers: githubHeaders });
      if (!res.ok) break;
      const data: any[] = await res.json();
      if (!Array.isArray(data) || data.length === 0) break;
      for (const c of data) {
        const iso = c?.commit?.author?.date ?? c?.commit?.committer?.date;
        const t = iso ? new Date(iso).getTime() : 0;
        if (!t) continue;
        const idx = Math.min(WEEKS - 1, Math.max(0, Math.floor((t - startMs) / weekMs)));
        buckets[idx]++;
      }
      if (data.length < 100) break;
    } catch {
      break;
    }
  }
  return buckets;
}

async function fetchTopTechnologies(name: string, fallbackLanguage: string): Promise<string[]> {
  try {
    const res = await fetch(`https://api.github.com/repos/${GITHUB_USERNAME}/${name}/languages`, {
      headers: githubHeaders,
    });
    if (!res.ok) return [fallbackLanguage || 'Unknown'];

    const langs = (await res.json()) as Record<string, number>;
    const sorted = Object.entries(langs)
      .sort(([, a], [, b]) => b - a)
      .map(([lang]) => lang)
      .slice(0, 2);

    if (sorted.length > 0) return sorted;
    return [fallbackLanguage || 'Unknown'];
  } catch {
    return [fallbackLanguage || 'Unknown'];
  }
}

async function fetchRepo(name: string, rank: number): Promise<Project> {
  const fallback: Project = {
    rank,
    name,
    description: 'No description available.',
    language: 'Unknown',
    technologies: ['Unknown'],
    stars: 0,
    forks: 0,
    url: `https://github.com/${GITHUB_USERNAME}/${name}`,
    topics: [],
    pushedAt: new Date().toISOString(),
    updatedAt: new Date().toISOString(),
    commitActivity: [],
  };
  try {
    const [repoRes, commitActivity] = await Promise.all([
      fetch(`https://api.github.com/repos/${GITHUB_USERNAME}/${name}`, {
        headers: githubHeaders,
      }),
      fetchCommitActivity(name),
    ]);
    if (!repoRes.ok) return { ...fallback, commitActivity };
    const repo: any = await repoRes.json();
    const primaryLanguage = repo.language ?? 'Unknown';
    const technologies = await fetchTopTechnologies(name, primaryLanguage);
    return {
      rank,
      name: repo.name,
      description: repo.description ?? 'No description available.',
      language: primaryLanguage,
      technologies,
      stars: repo.stargazers_count ?? 0,
      forks: repo.forks_count ?? 0,
      url: repo.html_url,
      topics: repo.topics ?? [],
      pushedAt: repo.pushed_at ?? repo.updated_at,
      updatedAt: repo.updated_at,
      commitActivity,
    };
  } catch {
    return fallback;
  }
}

// Discover repos dynamically, then fetch full data in parallel
const repoNames = await fetchTopRepoNames();
const projects: Project[] = await Promise.all(repoNames.map((name, i) => fetchRepo(name, i + 1)));

/**
 * Builds a seismograph-style SVG path (vertical spikes from a flat baseline).
 * ViewBox: 0 0 100 24. Baseline at y=21. Spikes grow upward (−y direction).
 * Returns the baseline path and the spikes path separately so each can be
 * styled independently. A CSS mask (left→right opacity) is applied via CSS.
 */
function buildSeismograph(data: number[]): { baseline: string; spikes: string; total: number } {
  const series = data?.length >= 2 ? data : new Array(52).fill(0);
  const W      = 100;
  const BASE_Y = 21;
  const MAX_H  = 17;   // max spike: 4px from SVG top edge
  const max    = Math.max(...series, 1);
  const step   = W / (series.length - 1);

  let spikes = '';
  series.forEach((v, i) => {
    if (v === 0) return;
    const x    = (i * step).toFixed(2);
    const topY = (BASE_Y - (v / max) * MAX_H).toFixed(2);
    spikes += `M${x},${BASE_Y}L${x},${topY}`;
  });

  return {
    baseline: `M0,${BASE_Y}L${W},${BASE_Y}`,
    // When all values are 0, render a flat line so the chart isn't empty
    spikes: spikes || `M0,${BASE_Y}L${W},${BASE_Y}`,
    total: series.reduce((s, v) => s + v, 0),
  };
}

// ── Simple Icons — fetched at build time, fill replaced with currentColor ──

const SIMPLE_ICONS_SLUG: Record<string, string> = {
  Python:     'python',
  TypeScript: 'typescript',
  JavaScript: 'javascript',
  Astro:      'astro',
  HTML:       'html5',
  CSS:        'css',
  Shell:      'gnubash',
  Go:         'go',
  Rust:       'rust',
  Markdown:   'markdown',
};

async function fetchIcon(language: string): Promise<string | null> {
  const slug = SIMPLE_ICONS_SLUG[language];
  if (!slug) return null;
  try {
    const res = await fetch(`https://cdn.simpleicons.org/${slug}`);
    if (!res.ok) return null;
    const svg = await res.text();
    // Replace every non-transparent fill so CSS can drive the color via currentColor
    return svg.replace(/fill="(?!none)[^"]+"/g, 'fill="currentColor"');
  } catch {
    return null;
  }
}

const uniqueLangs = [...new Set(projects.flatMap((p) => p.technologies))];
const iconEntries = await Promise.all(
  uniqueLangs.map(async (lang) => [lang, await fetchIcon(lang)] as const)
);
const languageIcons: Record<string, string | null> = Object.fromEntries(iconEntries);

// Fallback dot colors for languages without a Simple Icon
const LANGUAGE_COLORS: Record<string, string> = {
  Python:     '#3572A5',
  TypeScript: '#3178C6',
  JavaScript: '#F1E05A',
  Astro:      '#FF5D01',
  HTML:       '#E34C26',
  CSS:        '#563D7C',
  Shell:      '#89E051',
  Markdown:   '#083FA1',
  Go:         '#00ADD8',
  Rust:       '#DEA584',
  Unknown:    '#7A7A7A',
};

function relativeTime(iso: string): string {
  const then = new Date(iso).getTime();
  if (Number.isNaN(then)) return '';
  const diff  = Date.now() - then;
  const day   = 86400000;
  const days  = Math.floor(diff / day);
  if (days < 1)  return 'Pushed today';
  if (days < 2)  return 'Pushed yesterday';
  if (days < 30) return `${days}d ago`;
  const months = Math.floor(days / 30);
  if (months < 12) return `${months}mo ago`;
  const years = Math.floor(days / 365);
  return `${years}y ago`;
}

function formatDigestDate(iso: string): string {
  try {
    return new Date(iso).toLocaleDateString('en-US', {
      month: 'short', day: 'numeric', year: 'numeric',
    });
  } catch {
    return iso;
  }
}

const digest   = digestRaw as Digest;
const hasDigest = digest.source !== 'fallback' && digest.summary.length > 20;
---

<section id="projects" class="projects-section">

  <!-- ── Header ── -->
  <div class="projects-header">
    <span class="section-overline">
      Recent Activity
      <span class="projects-live-indicator" aria-hidden="true">
        <span class="projects-live-dot"></span>
        live
      </span>
    </span>
    <h2 class="section-title">Projects</h2>
    <p class="section-subtitle">Top 3 most recently active repos · refreshed on every deploy</p>
  </div>

  <!-- ── Daily Digest Callout ── -->
  {hasDigest && (
    <div class="digest-callout" role="complementary" aria-label="Yesterday's GitHub activity digest">
      <div class="digest-callout__left">
        <div class="digest-callout__meta">
          <span class="digest-badge">
            <span class="digest-dot" aria-hidden="true"></span>
            Yesterday
          </span>
          <time class="digest-callout__date" datetime={digest.date}>
            {formatDigestDate(digest.date)}
          </time>
        </div>
        <p class="digest-callout__summary">{digest.summary}</p>
      </div>
      <div class="digest-callout__stats">
        {digest.stats.commits > 0 && (
          <span class="digest-stat">
            <strong class="digest-stat__value">{digest.stats.commits}</strong>
            <span class="digest-stat__label">commits</span>
          </span>
        )}
        {(digest.stats.reposTouched?.length ?? 0) > 0 && (
          <span class="digest-stat">
            <strong class="digest-stat__value">{digest.stats.reposTouched.length}</strong>
            <span class="digest-stat__label">{digest.stats.reposTouched.length === 1 ? 'repo' : 'repos'}</span>
          </span>
        )}
        {digest.stats.pullRequests > 0 && (
          <span class="digest-stat">
            <strong class="digest-stat__value">{digest.stats.pullRequests}</strong>
            <span class="digest-stat__label">{digest.stats.pullRequests === 1 ? 'PR' : 'PRs'}</span>
          </span>
        )}
      </div>
    </div>
  )}

  <!-- ── Cards Grid ── -->
  <div class="projects-grid">
    {projects.map((p) => {
      const seismo = buildSeismograph(p.commitActivity);
      return (
        <article class={`project-card${p.rank === 1 ? ' project-card--top' : ''}`}>
          <a
            class="project-card-link"
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${p.name} on GitHub`}
          ></a>

          <div class="project-card-top">
            <div class="project-card-top-left">
              <span class="project-rank" aria-label={`Rank ${p.rank}`}>#{p.rank}</span>
              <span class="project-language-list" aria-label="Main technologies">
                {p.technologies.slice(0, 2).map((tech) => (
                  <span class="project-language">
                    {languageIcons[tech]
                      ? (
                        <span
                          class="project-language-icon"
                          aria-hidden="true"
                          set:html={languageIcons[tech]}
                        />
                      )
                      : (
                        <span
                          class="project-language-dot"
                          style={`background:${LANGUAGE_COLORS[tech] ?? LANGUAGE_COLORS.Unknown}`}
                          aria-hidden="true"
                        />
                      )
                    }
                    {tech}
                  </span>
                ))}
              </span>
            </div>
            <span class="project-updated">{relativeTime(p.pushedAt)}</span>
          </div>

          <h3 class="project-name">{p.name}</h3>
          <p class="project-description">{p.description}</p>

          {p.topics.length > 0 && (
            <ul class="project-topics" aria-label="Topics">
              {p.topics.slice(0, 3).map((t) => (
                <li class="project-topic">{t}</li>
              ))}
            </ul>
          )}

          <!-- Seismograph chart -->
          <div class="project-seismograph" aria-hidden="true">
            <div class="project-seismograph-label">
              <span>52 weeks</span>
              <span>{seismo.total} commits</span>
            </div>
            <svg
              class="seismograph-svg"
              viewBox="0 0 100 24"
              preserveAspectRatio="none"
            >
              <path
                d={seismo.baseline}
                fill="none"
                stroke="rgba(201,168,124,0.18)"
                stroke-width="0.5"
                vector-effect="non-scaling-stroke"
              />
              <path
                d={seismo.spikes}
                fill="none"
                stroke="rgba(201,168,124,0.82)"
                stroke-width="0.9"
                stroke-linecap="round"
                vector-effect="non-scaling-stroke"
              />
            </svg>
          </div>

          <div class="project-card-bottom">
            <div class="project-stats">
              <span class="project-stat" title="Stars">
                <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                  <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
                </svg>
                {p.stars}
              </span>
              <span class="project-stat" title="Forks">
                <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                  <path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 1 1.5 0v.878a2.25 2.25 0 0 1-2.25 2.25h-1.5v2.128a2.251 2.251 0 1 1-1.5 0V8.5h-1.5A2.25 2.25 0 0 1 3.5 6.25v-.878a2.25 2.25 0 1 1 1.5 0ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm6.75.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm-3 8.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z"/>
                </svg>
                {p.forks}
              </span>
            </div>
            <span class="project-view">
              GitHub
              <span class="arrow" aria-hidden="true">&rarr;</span>
            </span>
          </div>
        </article>
      );
    })}
  </div>

  <!-- ── CTA ── -->
  <div class="projects-cta">
    <a
      href={`https://github.com/${GITHUB_USERNAME}`}
      target="_blank"
      rel="noopener noreferrer"
      class="github-profile-btn"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
      </svg>
      <span>All projects on GitHub</span>
      <span class="arrow" aria-hidden="true">&rarr;</span>
    </a>
  </div>
</section>

<style>
  @import '../styles/projects.css';
</style>
