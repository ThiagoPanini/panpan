---
/**
 * Projects — featured GitHub repositories rendered as interactive cards.
 * Repo data and language icons are fetched from external APIs at build time.
 */

const GITHUB_USERNAME = 'ThiagoPanini';
const GITHUB_TOKEN = import.meta.env.GITHUB_ACCESS_TOKEN;
const FEATURED_REPOS = ['aidriven', 'aidriven-resources', 'panpan'];

interface Project {
  name: string;
  description: string;
  language: string;
  technologies: string[];
  stars: number;
  forks: number;
  url: string;
  topics: string[];
  updatedAt: string;
  commitActivity: number[];
}

const FALLBACK: Record<string, Project> = {
  aidriven: {
    name: 'aidriven',
    description: 'A platform for AI-driven analytics workflows and tooling.',
    language: 'Python',
    technologies: ['Python'],
    stars: 0,
    forks: 0,
    url: `https://github.com/${GITHUB_USERNAME}/aidriven`,
    topics: ['ai', 'analytics', 'python'],
    updatedAt: new Date().toISOString(),
    commitActivity: [],
  },
  'aidriven-resources': {
    name: 'aidriven-resources',
    description: 'Curated resources, templates and references for AI-driven engineering.',
    language: 'Markdown',
    technologies: ['Markdown'],
    stars: 0,
    forks: 0,
    url: `https://github.com/${GITHUB_USERNAME}/aidriven-resources`,
    topics: ['resources', 'ai', 'documentation'],
    updatedAt: new Date().toISOString(),
    commitActivity: [],
  },
  panpan: {
    name: 'panpan',
    description: 'Personal portfolio site built with Astro and GSAP.',
    language: 'Astro',
    technologies: ['Astro', 'CSS'],
    stars: 0,
    forks: 0,
    url: `https://github.com/${GITHUB_USERNAME}/panpan`,
    topics: ['astro', 'portfolio', 'typescript'],
    updatedAt: new Date().toISOString(),
    commitActivity: [],
  },
};

const githubHeaders = {
  Accept: 'application/vnd.github+json',
  ...(GITHUB_TOKEN ? { Authorization: `Bearer ${GITHUB_TOKEN}` } : {}),
};

/**
 * Fetch 52-week commit activity. Tries the stats endpoint first
 * (cheap, single request) and falls back to the commits list API,
 * which is synchronous and always responds. Guarantees 52 buckets.
 */
async function fetchCommitActivity(name: string): Promise<number[]> {
  const fromStats = await fetchFromStatsEndpoint(name);
  if (fromStats && fromStats.length >= 2 && fromStats.some((v) => v > 0)) {
    return fromStats;
  }
  const fromCommits = await fetchFromCommitsEndpoint(name);
  if (fromCommits.some((v) => v > 0)) return fromCommits;
  // Last resort: prefer whichever non-empty array we got, else 52 zeros.
  if (fromStats && fromStats.length >= 2) return fromStats;
  return new Array(52).fill(0);
}

/**
 * /stats/commit_activity is async on GitHub's side: it may answer
 * 202 (computing), or worse, 200 with an empty body while still
 * computing. Retry both cases with exponential backoff.
 */
async function fetchFromStatsEndpoint(name: string): Promise<number[] | null> {
  const url = `https://api.github.com/repos/${GITHUB_USERNAME}/${name}/stats/commit_activity`;
  const delays = [800, 1500, 2500, 4000, 6000];
  for (const delay of delays) {
    try {
      const res = await fetch(url, { headers: githubHeaders });
      if (res.status === 202) {
        await new Promise((r) => setTimeout(r, delay));
        continue;
      }
      if (res.status === 403 || res.status === 429) return null; // rate-limited
      if (!res.ok) return null;
      const data: Array<{ total: number }> = await res.json();
      if (!Array.isArray(data) || data.length === 0) {
        // 200 + empty body: GitHub is still computing — wait & retry.
        await new Promise((r) => setTimeout(r, delay));
        continue;
      }
      return data.map((w) => w.total ?? 0);
    } catch {
      return null;
    }
  }
  return null;
}

/**
 * Fallback: list commits from the past 52 weeks (paginated) and
 * bucket them by week. Synchronous on GitHub's side, always works
 * for any repo the token can read.
 */
async function fetchFromCommitsEndpoint(name: string): Promise<number[]> {
  const WEEKS = 52;
  const buckets = new Array(WEEKS).fill(0);
  const weekMs = 7 * 86400000;
  const since = new Date(Date.now() - WEEKS * weekMs);
  const startMs = since.getTime();

  for (let page = 1; page <= 10; page++) {
    try {
      const url =
        `https://api.github.com/repos/${GITHUB_USERNAME}/${name}/commits` +
        `?since=${since.toISOString()}&per_page=100&page=${page}`;
      const res = await fetch(url, { headers: githubHeaders });
      if (!res.ok) break;
      const data: any[] = await res.json();
      if (!Array.isArray(data) || data.length === 0) break;
      for (const c of data) {
        const iso = c?.commit?.author?.date ?? c?.commit?.committer?.date;
        const t = iso ? new Date(iso).getTime() : 0;
        if (!t) continue;
        const idx = Math.min(WEEKS - 1, Math.max(0, Math.floor((t - startMs) / weekMs)));
        buckets[idx]++;
      }
      if (data.length < 100) break;
    } catch {
      break;
    }
  }
  return buckets;
}

async function fetchTopTechnologies(name: string, fallbackLanguage: string): Promise<string[]> {
  try {
    const res = await fetch(`https://api.github.com/repos/${GITHUB_USERNAME}/${name}/languages`, {
      headers: githubHeaders,
    });
    if (!res.ok) return [fallbackLanguage || 'Unknown'];

    const langs = (await res.json()) as Record<string, number>;
    const sorted = Object.entries(langs)
      .sort(([, a], [, b]) => b - a)
      .map(([lang]) => lang)
      .slice(0, 2);

    if (sorted.length > 0) return sorted;
    return [fallbackLanguage || 'Unknown'];
  } catch {
    return [fallbackLanguage || 'Unknown'];
  }
}

async function fetchRepo(name: string): Promise<Project> {
  try {
    const [repoRes, commitActivity] = await Promise.all([
      fetch(`https://api.github.com/repos/${GITHUB_USERNAME}/${name}`, {
        headers: githubHeaders,
      }),
      fetchCommitActivity(name),
    ]);
    if (!repoRes.ok) return { ...FALLBACK[name], commitActivity };
    const repo: any = await repoRes.json();
    const primaryLanguage = repo.language ?? 'Unknown';
    const technologies = await fetchTopTechnologies(name, primaryLanguage);
    return {
      name: repo.name,
      description: repo.description ?? 'No description available.',
      language: primaryLanguage,
      technologies,
      stars: repo.stargazers_count ?? 0,
      forks: repo.forks_count ?? 0,
      url: repo.html_url,
      topics: repo.topics ?? [],
      updatedAt: repo.updated_at,
      commitActivity,
    };
  } catch {
    return FALLBACK[name];
  }
}

const projects: Project[] = await Promise.all(FEATURED_REPOS.map(fetchRepo));

/**
 * Build SVG path strings for a sparkline line + area fill.
 * Normalizes the series into a fixed viewBox (100 × 32).
 */
function buildSparkline(data: number[]): { line: string; area: string; total: number } {
  const series = data && data.length >= 2 ? data : new Array(52).fill(0);
  data = series;
  const W = 100;
  const H = 32;
  const PAD_Y = 2;
  const max = Math.max(...data, 1);
  const stepX = W / (data.length - 1);

  const coords = data.map((v, i) => {
    const x = i * stepX;
    const y = H - PAD_Y - (v / max) * (H - PAD_Y * 2);
    return [x, y] as const;
  });

  const line = 'M' + coords.map(([x, y]) => `${x.toFixed(2)},${y.toFixed(2)}`).join(' L');
  const area =
    `M0,${H} ` +
    'L' + coords.map(([x, y]) => `${x.toFixed(2)},${y.toFixed(2)}`).join(' L') +
    ` L${W},${H} Z`;
  const total = data.reduce((s, v) => s + v, 0);
  return { line, area, total };
}

// ── Simple Icons — fetched at build time, fill replaced with currentColor ──

const SIMPLE_ICONS_SLUG: Record<string, string> = {
  Python:     'python',
  TypeScript: 'typescript',
  JavaScript: 'javascript',
  Astro:      'astro',
  HTML:       'html5',
  CSS:        'css',
  Shell:      'gnubash',
  Go:         'go',
  Rust:       'rust',
  Markdown:   'markdown',
};

async function fetchIcon(language: string): Promise<string | null> {
  const slug = SIMPLE_ICONS_SLUG[language];
  if (!slug) return null;
  try {
    const res = await fetch(`https://cdn.simpleicons.org/${slug}`);
    if (!res.ok) return null;
    const svg = await res.text();
    // Replace every non-transparent fill so CSS can drive the color via currentColor
    return svg.replace(/fill="(?!none)[^"]+"/g, 'fill="currentColor"');
  } catch {
    return null;
  }
}

const uniqueLangs = [...new Set(projects.flatMap((p) => p.technologies))];
const iconEntries = await Promise.all(
  uniqueLangs.map(async (lang) => [lang, await fetchIcon(lang)] as const)
);
const languageIcons: Record<string, string | null> = Object.fromEntries(iconEntries);

// Fallback dot colors for languages without a Simple Icon
const LANGUAGE_COLORS: Record<string, string> = {
  Python:     '#3572A5',
  TypeScript: '#3178C6',
  JavaScript: '#F1E05A',
  Astro:      '#FF5D01',
  HTML:       '#E34C26',
  CSS:        '#563D7C',
  Shell:      '#89E051',
  Markdown:   '#083FA1',
  Go:         '#00ADD8',
  Rust:       '#DEA584',
  Unknown:    '#7A7A7A',
};

function relativeTime(iso: string): string {
  const then = new Date(iso).getTime();
  if (Number.isNaN(then)) return '';
  const diff = Date.now() - then;
  const day = 86400000;
  const days = Math.floor(diff / day);
  if (days < 1)  return 'Updated today';
  if (days < 2)  return 'Updated yesterday';
  if (days < 30) return `Updated ${days} days ago`;
  const months = Math.floor(days / 30);
  if (months < 12) return `Updated ${months} month${months === 1 ? '' : 's'} ago`;
  const years = Math.floor(days / 365);
  return `Updated ${years} year${years === 1 ? '' : 's'} ago`;
}
---

<section id="projects" class="projects-section">
  <div class="projects-header">
    <span class="section-overline">Featured Work</span>
    <h2 class="section-title">Projects</h2>
    <p class="section-subtitle">Open-source tools and platforms I'm building</p>
  </div>

  <div class="projects-grid">
    {projects.map((p) => {
      const spark = buildSparkline(p.commitActivity);
      return (
      <article class="project-card">
        <a
          class="project-card-link"
          href={p.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${p.name} on GitHub`}
        ></a>

        <div class="project-card-top">
          <span class="project-language-list" aria-label="Main technologies">
            {p.technologies.slice(0, 2).map((tech) => (
              <span class="project-language">
                {languageIcons[tech]
                  ? (
                    <span
                      class="project-language-icon"
                      aria-hidden="true"
                      set:html={languageIcons[tech]}
                    />
                  )
                  : (
                    <span
                      class="project-language-dot"
                      style={`background:${LANGUAGE_COLORS[tech] ?? LANGUAGE_COLORS.Unknown}`}
                      aria-hidden="true"
                    />
                  )
                }
                {tech}
              </span>
            ))}
          </span>
          <span class="project-updated">{relativeTime(p.updatedAt)}</span>
        </div>

        <h3 class="project-name">{p.name}</h3>
        <p class="project-description">{p.description}</p>

        {p.topics.length > 0 && (
          <ul class="project-topics" aria-label="Topics">
            {p.topics.slice(0, 4).map((t) => (
              <li class="project-topic">{t}</li>
            ))}
          </ul>
        )}

        {(
          <div class="project-sparkline" aria-hidden="true">
            <div class="project-sparkline-label">
              <span>Last 52 weeks</span>
              <span>{spark.total} commits</span>
            </div>
            <svg
              class="sparkline-svg"
              viewBox="0 0 100 32"
              preserveAspectRatio="none"
              role="img"
              aria-label={`${spark.total} commits over the last 52 weeks`}
            >
              <defs>
                <linearGradient id={`spark-grad-${p.name}`} x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0%" stop-color="rgba(201,168,124,0.35)" />
                  <stop offset="100%" stop-color="rgba(201,168,124,0)" />
                </linearGradient>
              </defs>
              <path d={spark.area} fill={`url(#spark-grad-${p.name})`} />
              <path
                d={spark.line}
                fill="none"
                stroke="rgba(201,168,124,0.85)"
                stroke-width="1.25"
                stroke-linecap="round"
                stroke-linejoin="round"
                vector-effect="non-scaling-stroke"
              />
            </svg>
          </div>
        )}
        {/* spark always rendered */}

        <div class="project-card-bottom">
          <div class="project-stats">
            <span class="project-stat" title="Stars">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
              </svg>
              {p.stars}
            </span>
            <span class="project-stat" title="Forks">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 1 1.5 0v.878a2.25 2.25 0 0 1-2.25 2.25h-1.5v2.128a2.251 2.251 0 1 1-1.5 0V8.5h-1.5A2.25 2.25 0 0 1 3.5 6.25v-.878a2.25 2.25 0 1 1 1.5 0ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm6.75.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm-3 8.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z"/>
              </svg>
              {p.forks}
            </span>
          </div>
          <span class="project-view">
            View on GitHub
            <span class="arrow" aria-hidden="true">&rarr;</span>
          </span>
        </div>
      </article>
      );
    })}
  </div>

  <div class="projects-cta">
    <a
      href={`https://github.com/${GITHUB_USERNAME}`}
      target="_blank"
      rel="noopener noreferrer"
      class="github-profile-btn"
    >
      <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
      </svg>
      <span>View all projects on GitHub</span>
      <span class="arrow" aria-hidden="true">&rarr;</span>
    </a>
  </div>
</section>

<style>
  @import '../styles/projects.css';
</style>
