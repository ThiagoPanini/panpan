---
interface AITool {
  name: string;
  provider: string;
  tier: string;
  description: string;
  iconSlug: string;
  accentColor: string;
  tags: string[];
}

const PERSONAL_TOOLS: AITool[] = [
  {
    name: "Claude Code",
    provider: "Anthropic",
    tier: "Pro",
    description: "My go-to coding agent for complex refactors, architecture decisions, and long-context reasoning.",
    iconSlug: "anthropic",
    accentColor: "#CC785C",
    tags: ["Coding Agent", "Architecture", "Long Context"],
  },
  {
    name: "GitHub Copilot",
    provider: "Microsoft",
    tier: "Pro",
    description: "Inline completions and chat right inside my editor — never leave VSCode flow state.",
    iconSlug: "githubcopilot",
    accentColor: "#6E40C9",
    tags: ["Autocomplete", "IDE Native", "Chat"],
  },
  {
    name: "ChatGPT",
    provider: "OpenAI",
    tier: "Plus",
    description: "Versatile assistant for brainstorming, writing, quick research, and image generation.",
    iconSlug: "openai",
    accentColor: "#10A37F",
    tags: ["General Purpose", "Writing", "Research"],
  },
];

const WORK_TOOLS: AITool[] = [
  {
    name: "GitHub Copilot",
    provider: "Microsoft",
    tier: "Enterprise",
    description: "Organization-wide coding assistant with policy controls, fine-tuned for our internal codebase.",
    iconSlug: "githubcopilot",
    accentColor: "#6E40C9",
    tags: ["Enterprise", "Autocomplete", "Policy-Controlled"],
  },
  {
    name: "Devin",
    provider: "Cognition",
    tier: "Core",
    description: "Autonomous AI software engineer for end-to-end task delegation across longer workflows.",
    iconSlug: "cognition",
    accentColor: "#5B7CFA",
    tags: ["Autonomous Agent", "Task Delegation", "End-to-End"],
  },
  {
    name: "Microsoft 365 Copilot",
    provider: "Microsoft",
    tier: "Enterprise",
    description: "AI embedded in Word, Excel, Teams, and Outlook to accelerate everyday productivity.",
    iconSlug: "microsoftcopilot",
    accentColor: "#0078D4",
    tags: ["Productivity", "Office Suite", "Teams"],
  },
];

// ── Simple Icons — fetched at build time ──

async function fetchIcon(slug: string): Promise<string | null> {
  try {
    const res = await fetch(`https://cdn.simpleicons.org/${slug}`);
    if (!res.ok) return null;
    const svg = await res.text();
    return svg.replace(/fill="(?!none)[^"]+"/g, 'fill="currentColor"');
  } catch {
    return null;
  }
}

const allSlugs = [...new Set([...PERSONAL_TOOLS, ...WORK_TOOLS].map((t) => t.iconSlug))];
const iconEntries = await Promise.all(
  allSlugs.map(async (slug) => [slug, await fetchIcon(slug)] as const)
);
const toolIcons: Record<string, string | null> = Object.fromEntries(iconEntries);

// Helper to render a tool card (reused for both hero and compact variants)
function renderToolData(tool: AITool) {
  return { tool, icon: toolIcons[tool.iconSlug] };
}

const personalData = PERSONAL_TOOLS.map(renderToolData);
const workData = WORK_TOOLS.map(renderToolData);
---

<section id="ai-usage" class="ai-usage-section">
  <div class="ai-usage-header">
    <span class="section-overline">How I Work</span>
    <h2 class="section-title">AI in My Stack</h2>
    <p class="section-subtitle">Tools I rely on daily — across personal projects and professional workflows</p>
  </div>

  <!-- ── Environment Selector ── -->
  <div class="ai-tab-bar" role="tablist" aria-label="Environment selector">
    <button
      role="tab"
      id="tab-personal"
      class="ai-tab ai-tab--active"
      aria-selected="true"
      aria-controls="panel-personal"
      tabindex="0"
    >
      <span class="ai-tab-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
          <circle cx="12" cy="7" r="4" />
        </svg>
      </span>
      Personal
      <span class="ai-tab-count">{PERSONAL_TOOLS.length}</span>
    </button>
    <button
      role="tab"
      id="tab-work"
      class="ai-tab"
      aria-selected="false"
      aria-controls="panel-work"
      tabindex="-1"
    >
      <span class="ai-tab-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="7" width="20" height="14" rx="2" ry="2" />
          <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" />
        </svg>
      </span>
      Work
      <span class="ai-tab-count">{WORK_TOOLS.length}</span>
    </button>
    <span class="ai-tab-indicator" aria-hidden="true"></span>
  </div>

  <!-- ── Personal Panel ── -->
  <div
    role="tabpanel"
    id="panel-personal"
    class="ai-panel ai-panel--active"
    aria-labelledby="tab-personal"
  >
    <div class="ai-bento">
      {personalData.map(({ tool, icon }, i) => (
        <article
          class={`ai-card ${i === 0 ? 'ai-card--hero' : 'ai-card--compact'}`}
          style={`--tool-accent: ${tool.accentColor}`}
          aria-label={`${tool.name} by ${tool.provider}`}
        >
          <div class="ai-card__glow" aria-hidden="true"></div>
          <div class="ai-card__header">
            {icon ? (
              <span
                class="ai-card__icon"
                aria-label={`${tool.provider} icon`}
                set:html={icon}
              />
            ) : (
              <span
                class="ai-card__icon-dot"
                style={`background: ${tool.accentColor}`}
                aria-label={`${tool.provider} icon`}
              />
            )}
            <div class="ai-card__meta">
              <h3 class="ai-card__name">{tool.name}</h3>
              <span class="ai-card__provider">{tool.provider}</span>
            </div>
            <span class="ai-card__tier">{tool.tier}</span>
          </div>
          <p class="ai-card__desc">{tool.description}</p>
          <ul class="ai-card__tags" aria-label="Capabilities">
            {tool.tags.map((tag) => (
              <li class="ai-card__tag">{tag}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>

  <!-- ── Work Panel ── -->
  <div
    role="tabpanel"
    id="panel-work"
    class="ai-panel"
    aria-labelledby="tab-work"
    hidden
  >
    <div class="ai-bento">
      {workData.map(({ tool, icon }, i) => (
        <article
          class={`ai-card ${i === 0 ? 'ai-card--hero' : 'ai-card--compact'}`}
          style={`--tool-accent: ${tool.accentColor}`}
          aria-label={`${tool.name} by ${tool.provider}`}
        >
          <div class="ai-card__glow" aria-hidden="true"></div>
          <div class="ai-card__header">
            {icon ? (
              <span
                class="ai-card__icon"
                aria-label={`${tool.provider} icon`}
                set:html={icon}
              />
            ) : (
              <span
                class="ai-card__icon-dot"
                style={`background: ${tool.accentColor}`}
                aria-label={`${tool.provider} icon`}
              />
            )}
            <div class="ai-card__meta">
              <h3 class="ai-card__name">{tool.name}</h3>
              <span class="ai-card__provider">{tool.provider}</span>
            </div>
            <span class="ai-card__tier">{tool.tier}</span>
          </div>
          <p class="ai-card__desc">{tool.description}</p>
          <ul class="ai-card__tags" aria-label="Capabilities">
            {tool.tags.map((tag) => (
              <li class="ai-card__tag">{tag}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  @import '../styles/ai-usage.css';
</style>
