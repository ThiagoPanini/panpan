---
/**
 * AI Usage — tools used across personal and professional environments.
 * Provider icons are fetched at build time from Simple Icons CDN.
 */

interface AITool {
  name: string;
  provider: string;
  tier: string;
  description: string;
  iconSlug: string;
  accentColor: string;
  tags: string[];
}

const PERSONAL_TOOLS: AITool[] = [
  {
    name: "Claude Code",
    provider: "Anthropic",
    tier: "Pro",
    description: "My go-to coding agent for complex refactors, architecture decisions, and long-context reasoning.",
    iconSlug: "anthropic",
    accentColor: "#CC785C",
    tags: ["Coding Agent", "Architecture", "Long Context"],
  },
  {
    name: "GitHub Copilot",
    provider: "Microsoft",
    tier: "Pro",
    description: "Inline completions and chat right inside my editor — never leave VSCode flow state.",
    iconSlug: "githubcopilot",
    accentColor: "#6E40C9",
    tags: ["Autocomplete", "IDE Native", "Chat"],
  },
  {
    name: "ChatGPT",
    provider: "OpenAI",
    tier: "Plus",
    description: "Versatile assistant for brainstorming, writing, quick research, and image generation.",
    iconSlug: "openai",
    accentColor: "#10A37F",
    tags: ["General Purpose", "Writing", "Research"],
  },
];

const WORK_TOOLS: AITool[] = [
  {
    name: "GitHub Copilot",
    provider: "Microsoft",
    tier: "Enterprise",
    description: "Organization-wide coding assistant with policy controls, fine-tuned for our internal codebase.",
    iconSlug: "githubcopilot",
    accentColor: "#6E40C9",
    tags: ["Enterprise", "Autocomplete", "Policy-Controlled"],
  },
  {
    name: "Devin",
    provider: "Cognition",
    tier: "Core",
    description: "Autonomous AI software engineer for end-to-end task delegation across longer workflows.",
    iconSlug: "cognition",
    accentColor: "#5B7CFA",
    tags: ["Autonomous Agent", "Task Delegation", "End-to-End"],
  },
  {
    name: "Microsoft 365 Copilot",
    provider: "Microsoft",
    tier: "Enterprise",
    description: "AI embedded in Word, Excel, Teams, and Outlook to accelerate everyday productivity.",
    iconSlug: "microsoftcopilot",
    accentColor: "#0078D4",
    tags: ["Productivity", "Office Suite", "Teams"],
  },
];

// ── Simple Icons — fetched at build time ──

async function fetchIcon(slug: string): Promise<string | null> {
  try {
    const res = await fetch(`https://cdn.simpleicons.org/${slug}`);
    if (!res.ok) return null;
    const svg = await res.text();
    return svg.replace(/fill="(?!none)[^"]+"/g, 'fill="currentColor"');
  } catch {
    return null;
  }
}

const allSlugs = [...new Set([...PERSONAL_TOOLS, ...WORK_TOOLS].map((t) => t.iconSlug))];
const iconEntries = await Promise.all(
  allSlugs.map(async (slug) => [slug, await fetchIcon(slug)] as const)
);
const toolIcons: Record<string, string | null> = Object.fromEntries(iconEntries);
---

<section id="ai-usage" class="ai-usage-section">
  <div class="ai-usage-header">
    <span class="section-overline">How I Work</span>
    <h2 class="section-title">AI in My Stack</h2>
    <p class="section-subtitle">Tools I rely on daily — across personal projects and professional workflows</p>
  </div>

  <div class="ai-environments">
    <!-- Personal -->
    <div class="ai-environment">
      <div class="ai-env-label">
        <span class="ai-env-label-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
            <circle cx="12" cy="7" r="4" />
          </svg>
        </span>
        Personal
        <span class="ai-env-count">{PERSONAL_TOOLS.length} tools</span>
      </div>
      <ul class="ai-tools-list">
        {PERSONAL_TOOLS.map((tool) => (
          <li>
            <article
              class="ai-tool-card"
              style={`--tool-accent: ${tool.accentColor}`}
              aria-label={`${tool.name} by ${tool.provider}`}
            >
              <div class="ai-tool-top">
                {toolIcons[tool.iconSlug] ? (
                  <span
                    class="ai-tool-icon"
                    aria-label={`${tool.provider} icon`}
                    set:html={toolIcons[tool.iconSlug]}
                  />
                ) : (
                  <span
                    class="ai-tool-icon-dot"
                    style={`background: ${tool.accentColor}`}
                    aria-label={`${tool.provider} icon`}
                  />
                )}
                <div class="ai-tool-info">
                  <h3 class="ai-tool-name">{tool.name}</h3>
                  <span class="ai-tool-provider">{tool.provider}</span>
                </div>
                <span class="ai-tool-tier">{tool.tier}</span>
              </div>
              <p class="ai-tool-description">{tool.description}</p>
              <ul class="ai-tool-tags" aria-label="Capabilities">
                {tool.tags.map((tag) => (
                  <li class="ai-tool-tag">{tag}</li>
                ))}
              </ul>
            </article>
          </li>
        ))}
      </ul>
    </div>

    <!-- Work -->
    <div class="ai-environment">
      <div class="ai-env-label">
        <span class="ai-env-label-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2" />
            <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" />
          </svg>
        </span>
        Work
        <span class="ai-env-count">{WORK_TOOLS.length} tools</span>
      </div>
      <ul class="ai-tools-list">
        {WORK_TOOLS.map((tool) => (
          <li>
            <article
              class="ai-tool-card"
              style={`--tool-accent: ${tool.accentColor}`}
              aria-label={`${tool.name} by ${tool.provider}`}
            >
              <div class="ai-tool-top">
                {toolIcons[tool.iconSlug] ? (
                  <span
                    class="ai-tool-icon"
                    aria-label={`${tool.provider} icon`}
                    set:html={toolIcons[tool.iconSlug]}
                  />
                ) : (
                  <span
                    class="ai-tool-icon-dot"
                    style={`background: ${tool.accentColor}`}
                    aria-label={`${tool.provider} icon`}
                  />
                )}
                <div class="ai-tool-info">
                  <h3 class="ai-tool-name">{tool.name}</h3>
                  <span class="ai-tool-provider">{tool.provider}</span>
                </div>
                <span class="ai-tool-tier">{tool.tier}</span>
              </div>
              <p class="ai-tool-description">{tool.description}</p>
              <ul class="ai-tool-tags" aria-label="Capabilities">
                {tool.tags.map((tag) => (
                  <li class="ai-tool-tag">{tag}</li>
                ))}
              </ul>
            </article>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  @import '../styles/ai-usage.css';
</style>
